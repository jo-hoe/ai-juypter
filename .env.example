# Point these at any OpenAI/Anthropic-compatible proxy.
# Copy this file to .env and fill in your values.
# The .env file is git-ignored — never commit real credentials.

ANTHROPIC_AUTH_TOKEN=test-key
ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
OPENAI_API_KEY=test-key
OPENAI_BASE_URL=http://localhost:6655/openai/v1
